# Backend (copy to `.env` in project root or set in your process manager)

# Production: set NODE_ENV=production in your process manager / container.
NODE_ENV=development

# Production: required, at least 32 random characters (e.g. openssl rand -hex 32)
JWT_SECRET=change-me
# Production cookie behavior (recommended for subdomain auth-gating)
COOKIE_DOMAIN=.alrusco.com
# COOKIE_SECURE=true

# Production first-time admin: set to true only for the initial POST /api/auth/bootstrap, then remove.
# ALLOW_BOOTSTRAP=true

# Optional: storage location for SQLite + uploads (default: ./data).
# This is deterministic and does not depend on the process working directory
# (avoids auth.db / uploads pointing somewhere else on pm2/unRAID restarts).
# DATA_DIR=

# Optional: env-driven initial admin creation (only when the DB is empty).
# Set to `true` only for the very first setup, then set it back to `false` (or unset).
# Requires ADMIN_USERNAME and ADMIN_PASSWORD.
# ALLOW_ADMIN_ENV_INIT=false

# Optional: initial admin credentials for a fresh install (when the users table is empty).
# These values are only used when `ALLOW_ADMIN_ENV_INIT=true`.
# The server creates the admin using these values, but does NOT set up TOTP yet.
# On first sign-in, you'll see a QR code to finish 2FA enrollment.
# ADMIN_USERNAME=
# ADMIN_PASSWORD= (min 12 characters)

# Emergency: set a long random secret (24+ chars), call POST /api/auth/reset-admin-credentials with your
# chosen username/password + this secret in the JSON body, enroll TOTP from the response, then REMOVE
# this line and restart. Example: openssl rand -hex 32
# ADMIN_CREDENTIAL_RESET_SECRET=

# Optional: send HSTS header only when the site is always served over HTTPS at this hostname.
# ENABLE_HSTS=true

# Only if CSP blocks something you need: CSP_DISABLE=true (avoid in production)
# Log public /api/photos query params (default off): DEBUG_PHOTOS_API=true

# Optional tuning
# JSON_BODY_LIMIT=512kb
# GLOBAL_RATE_LIMIT_MAX=1200
# EXTEND_SESSION_RATE_LIMIT_MAX=40
# TRUST_PROXY_HOPS=1
# APPS_RATE_LIMIT_MAX=120
#
# Node HTTP server timeouts (defense-in-depth; safe defaults are set in code)
# HTTP_HEADERS_TIMEOUT_MS=70000
# HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
# HTTP_REQUEST_TIMEOUT_MS=900000

# GET /apps/:id redirects — production allows only https URLs whose host matches these suffixes (comma-separated).
# LAN_APP_REDIRECT_HOST_SUFFIXES=alrusco.com
# Dev: allow http(s)://localhost when needed: LAN_APP_REDIRECT_ALLOW_LOCALHOST=true

# Optional override: if omitted, server auto-generates a random 32-byte key on first startup
# and persists it in SQLite settings for future restarts.
#
# Manual format if you provide one: 64-char hex OR base64 encoding of 32 raw bytes.
# CREDENTIALS_ENCRYPTION_KEY=

# Optional: override GitHub credentials from the database (e.g. in Docker)
# GITHUB_TOKEN=
# GITHUB_USERNAME=
# GITHUB_ORG=

# Optional sync behavior (defaults: exclude forks and archived repos)
# GITHUB_SYNC_EXCLUDE_FORKS=false
# GITHUB_SYNC_EXCLUDE_ARCHIVED=false

# GITHUB_API_USER_AGENT=YourApp/1.0

# Weather: set WEATHER_FIXED_LOCATION=true in production to ignore ?lat=&lon= and use only WEATHER_LAT / WEATHER_LON
# WEATHER_API_KEY=
# WEATHER_FIXED_LOCATION=true
# WEATHER_LAT=
# WEATHER_LON=

# Dashboard feeds (RSS)
# RSS_MIN_REFRESH_MS=600000
# RSS_ADMIN_RATE_LIMIT_MAX=30

# Market data (Alpha Vantage)
# MARKET_PROVIDER=alpha_vantage   # alpha_vantage | finnhub
# ALPHAVANTAGE_API_KEY=
# FINNHUB_API_KEY=
# MARKET_CACHE_TTL_MS=300000
# MARKET_RATE_LIMIT_MAX=60

# AI Search
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# AI_RATE_LIMIT_MAX=30
