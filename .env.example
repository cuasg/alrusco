# Backend (copy to `.env` in project root or set in your process manager)

# Production: set NODE_ENV=production in your process manager / container.
NODE_ENV=development

# Production: required, at least 32 random characters (e.g. openssl rand -hex 32)
JWT_SECRET=change-me
# Production cookie behavior (recommended for subdomain auth-gating)
COOKIE_DOMAIN=.alrusco.com
# COOKIE_SECURE=true

# Production first-time admin: set to true only for the initial POST /api/auth/bootstrap, then remove.
# ALLOW_BOOTSTRAP=true

# Optional: send HSTS header only when the site is always served over HTTPS at this hostname.
# ENABLE_HSTS=true

# Only if CSP blocks something you need: CSP_DISABLE=true (avoid in production)
# Log public /api/photos query params (default off): DEBUG_PHOTOS_API=true

# Optional tuning
# JSON_BODY_LIMIT=512kb
# GLOBAL_RATE_LIMIT_MAX=1200
# EXTEND_SESSION_RATE_LIMIT_MAX=40
# TRUST_PROXY_HOPS=1

# GET /apps/:id redirects — production allows only https URLs whose host matches these suffixes (comma-separated).
# LAN_APP_REDIRECT_HOST_SUFFIXES=alrusco.com
# Dev: allow http(s)://localhost when needed: LAN_APP_REDIRECT_ALLOW_LOCALHOST=true

CREDENTIALS_ENCRYPTION_KEY=
# 32-byte key: `openssl rand -hex 32` (paste hex string) OR base64 encoding of 32 raw bytes.
# Required to store a GitHub PAT from the Settings UI.

# Optional: override GitHub credentials from the database (e.g. in Docker)
# GITHUB_TOKEN=
# GITHUB_USERNAME=
# GITHUB_ORG=

# Optional sync behavior (defaults: exclude forks and archived repos)
# GITHUB_SYNC_EXCLUDE_FORKS=false
# GITHUB_SYNC_EXCLUDE_ARCHIVED=false

# GITHUB_API_USER_AGENT=YourApp/1.0

# Weather: set WEATHER_FIXED_LOCATION=true in production to ignore ?lat=&lon= and use only WEATHER_LAT / WEATHER_LON
# WEATHER_FIXED_LOCATION=true
